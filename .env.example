# ─── ARCH Platform — Environment Variables ───────────────────────────────────
# Copy this file to .env.local and fill in the values before running locally.
# On Vercel, add these in: Project Settings → Environment Variables

# ── Next.js ──────────────────────────────────────────────────────────────────
# Public URL of the deployed app (set automatically by Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Authentication (e.g. NextAuth.js / Clerk / Auth.js) ──────────────────────
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Database (e.g. Supabase / PlanetScale / Neon) ────────────────────────────
DATABASE_URL=

# ── Supabase (if used) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── File Storage (e.g. Vercel Blob / AWS S3 / Cloudinary) ────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Email (e.g. Resend / SendGrid) ───────────────────────────────────────────
RESEND_API_KEY=

# ── Analytics (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
